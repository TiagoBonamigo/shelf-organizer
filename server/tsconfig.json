{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "../dist/server",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noUncheckedIndexedAccess": false,
    "types": ["node"]
  },
  "include": ["**/*.ts", "../web/src/lib/shared-types.ts"]
}
